{
  "job_id": "finance-hourly",
  "ingestor_plugin": "finance",
  "analyzer_plugin": {
    "provider": "ollama",
    "model": "llama3",
    "temperature": 0.2,
    "prompt_template_id": "finance-v1"
  },
  "pipeline_settings": {
    "max_parallelism": 8,
    "max_retries": 3,
    "cron": "0 * * * *"
  },
  "storage_policy": {
    "raw_retention_days": 30,
    "analyzed_retention_days": 365,
    "persist_artifacts": true
  }
}
